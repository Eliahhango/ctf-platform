{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/static/:path*",
      "destination": "/static/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/api_responses/:path*",
      "destination": "/api_responses/:path*"
    },
    {
      "source": "/_external/:path*",
      "destination": "/_external/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
